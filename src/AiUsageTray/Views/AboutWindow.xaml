<Window x:Class="AiUsageTray.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About AI Usage Tray" Height="240" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <StackPanel Margin="24" VerticalAlignment="Center">
        <TextBlock Text="AI Usage Tray" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.PrimaryText}"/>
        <TextBlock x:Name="VersionText" Margin="0,6,0,0" Foreground="{DynamicResource Brush.SecondaryText}"/>
        <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Foreground="{DynamicResource Brush.PrimaryText}"
                   Text="Monitors coding-AI usage and quota for OpenAI Codex and Claude Code, entirely locally. No prompt content, credentials, or usage data ever leave your machine."/>
        <TextBlock Margin="0,16,0,0" Foreground="{DynamicResource Brush.SecondaryText}"
                   Text="Privacy: read-only quota requests only. Never reads OAuth tokens or prompt content."/>
    </StackPanel>
</Window>
