<Window x:Class="AiUsageTray.Views.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AiUsageTray.ViewModels"
        xmlns:views="clr-namespace:AiUsageTray.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:FlyoutViewModel}"
        Title="AI Usage"
        Width="410"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Deactivated="OnDeactivated"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>
        <views:LevelToBrushConverter x:Key="LevelToBrush"/>
        <views:ProgressLevelToBrushConverter x:Key="ProgressLevelToBrush"/>
        <views:StringNullOrEmptyToVisibilityConverter x:Key="StringToVis"/>
        <views:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate x:Key="WindowRowTemplate" DataType="{x:Type vm:UsageWindowRowViewModel}">
            <Grid Margin="0,6,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding DisplayName}" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.PrimaryText}"/>
                <Grid Grid.Row="1" Margin="0,3,0,3" Visibility="{Binding HasPercent, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Value="{Binding UsedPercentValue, Mode=OneWay}" Style="{StaticResource FlyoutProgressBar}"
                                 Foreground="{Binding ProgressLevel, Converter={StaticResource ProgressLevelToBrush}}"/>
                </Grid>
                <TextBlock Grid.Row="2" Text="{Binding UsageSummaryText}" FontSize="11.5"
                           Foreground="{DynamicResource Brush.SecondaryText}"/>
                <TextBlock Grid.Row="2" Text="{Binding ResetText}" FontSize="11.5" HorizontalAlignment="Right"
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           Visibility="{Binding ResetText, Converter={StaticResource StringToVis}}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ProviderCardTemplate" DataType="{x:Type vm:ProviderCardViewModel}">
            <Border Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="14,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.PrimaryText}"/>
                            <TextBlock Text=" — " Foreground="{DynamicResource Brush.SecondaryText}"
                                       Visibility="{Binding PlanName, Converter={StaticResource StringToVis}}"/>
                            <TextBlock Text="{Binding PlanName}" FontSize="13" Foreground="{DynamicResource Brush.SecondaryText}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{Binding StatusLevel, Converter={StaticResource LevelToBrush}}" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="11.5" Foreground="{DynamicResource Brush.SecondaryText}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding AccountLabel}" FontSize="11.5" Margin="0,2,0,0"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Visibility="{Binding AccountLabel, Converter={StaticResource StringToVis}}"/>

                    <Border Background="Transparent" Margin="0,6,0,0"
                            Visibility="{Binding Message, Converter={StaticResource StringToVis}}">
                        <TextBlock Text="{Binding Message}" FontSize="11.5" TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.Warning}"/>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Windows}" ItemTemplate="{StaticResource WindowRowTemplate}"
                                  Visibility="{Binding HasWindows, Converter={StaticResource BoolToVis}}"/>

                    <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,6,0,0"
                                  Visibility="{Binding HasMetrics, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11.5" Foreground="{DynamicResource Brush.SecondaryText}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding LastUpdatedText}" FontSize="10.5" Margin="0,8,0,0"
                               Foreground="{DynamicResource Brush.SecondaryText}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.WindowBackground}" BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.28" Color="Black"/>
        </Border.Effect>
        <Grid Margin="16,14,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="AI Usage" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Brush.PrimaryText}"/>
                <Button Grid.Column="1" Style="{StaticResource FlyoutIconButton}" Command="{Binding RefreshCommand}" ToolTip="Refresh now">
                    <TextBlock Text="&#8635; Refresh" FontSize="12" Foreground="{DynamicResource Brush.PrimaryText}"/>
                </Button>
            </Grid>

            <TextBlock Grid.Row="1" Text="{Binding LastGlobalRefreshText}" FontSize="11" Margin="0,2,0,12"
                       Foreground="{DynamicResource Brush.SecondaryText}"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="520">
                <ItemsControl ItemsSource="{Binding Providers}" ItemTemplate="{StaticResource ProviderCardTemplate}"/>
            </ScrollViewer>

            <Button Grid.Row="3" Style="{StaticResource FlyoutIconButton}" Command="{Binding OpenSettingsCommand}"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
                <TextBlock Text="Settings" FontSize="12" Foreground="{DynamicResource Brush.PrimaryText}"/>
            </Button>
        </Grid>
    </Border>
</Window>
