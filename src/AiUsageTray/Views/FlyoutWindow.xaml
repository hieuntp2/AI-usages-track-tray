<Window x:Class="AiUsageTray.Views.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AiUsageTray.ViewModels"
        xmlns:views="clr-namespace:AiUsageTray.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:FlyoutViewModel}"
        Title="AI Usage"
        Width="410"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Deactivated="OnDeactivated"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.Resources>
        <views:LevelToBrushConverter x:Key="LevelToBrush"/>
        <views:ProgressLevelToBrushConverter x:Key="ProgressLevelToBrush"/>
        <views:StringNullOrEmptyToVisibilityConverter x:Key="StringToVis"/>
        <views:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate x:Key="WindowRowTemplate" DataType="{x:Type vm:UsageWindowRowViewModel}">
            <Grid Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Window name left, compact value right ("16%" / "300 / 1500 requests"). -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding DisplayName}" FontSize="12" VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.PrimaryText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding HeadlineValueText}" FontSize="12.5" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{Binding ProgressLevel, Converter={StaticResource ProgressLevelToBrush}}"/>
                </Grid>

                <ProgressBar Grid.Row="1" Margin="0,6,0,0"
                             Value="{Binding UsedPercentValue, Mode=OneWay}" Style="{StaticResource FlyoutProgressBar}"
                             Foreground="{Binding ProgressLevel, Converter={StaticResource ProgressLevelToBrush}}"
                             Visibility="{Binding HasPercent, Converter={StaticResource BoolToVis}}"/>

                <TextBlock Grid.Row="2" Text="{Binding ResetText}" FontSize="11" Margin="0,4,0,0"
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           Visibility="{Binding ResetText, Converter={StaticResource StringToVis}}"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ProviderCardTemplate" DataType="{x:Type vm:ProviderCardViewModel}">
            <!-- Unconnected providers render no card at all; they stay visible in Settings. -->
            <Border Background="{DynamicResource Brush.CardBackground}" BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1" CornerRadius="10" Margin="0,0,0,8" Padding="14,12,14,10"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.PrimaryText}"/>
                            <Border Background="{DynamicResource Brush.PillBackground}" CornerRadius="4"
                                    Padding="6,1.5" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="{Binding PlanName, Converter={StaticResource StringToVis}}">
                                <TextBlock Text="{Binding PlanName}" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.PillText}"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                    ToolTip="{Binding LastUpdatedText}">
                            <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,1,5,0"
                                     Fill="{Binding StatusLevel, Converter={StaticResource LevelToBrush}}"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="11" MaxWidth="150"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.SecondaryText}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding AccountLabel}" FontSize="11" Margin="0,2,0,0"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Visibility="{Binding AccountLabel, Converter={StaticResource StringToVis}}"/>

                    <TextBlock Text="{Binding Message}" FontSize="11" TextWrapping="Wrap" Margin="0,7,0,0"
                               Foreground="{DynamicResource Brush.Warning}"
                               Visibility="{Binding Message, Converter={StaticResource StringToVis}}"/>

                    <ItemsControl ItemsSource="{Binding Windows}" ItemTemplate="{StaticResource WindowRowTemplate}"
                                  Visibility="{Binding HasWindows, Converter={StaticResource BoolToVis}}"/>

                    <StackPanel Visibility="{Binding HasMetrics, Converter={StaticResource BoolToVis}}">
                        <Border Height="1" Background="{DynamicResource Brush.Separator}" Margin="0,11,0,7"/>
                        <ItemsControl ItemsSource="{Binding Metrics}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" Margin="0,1,0,0"
                                               Foreground="{DynamicResource Brush.SecondaryText}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="{Binding LastUpdatedText}" FontSize="10" Margin="0,8,0,0"
                               HorizontalAlignment="Right" Opacity="0.75"
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Visibility="{Binding LastUpdatedText, Converter={StaticResource StringToVis}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.WindowBackground}" BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.28" Color="Black"/>
        </Border.Effect>
        <Grid Margin="14,12,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: title + subtitle left, icon actions right. -->
            <Grid Grid.Row="0" Margin="2,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="AI Usage" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.PrimaryText}"/>
                    <TextBlock Text="{Binding LastGlobalRefreshText}" FontSize="10.5" Margin="0,1,0,0"
                               Foreground="{DynamicResource Brush.SecondaryText}"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource FlyoutGlyphButton}" Content="&#xE72C;"
                        Command="{Binding RefreshCommand}" ToolTip="Refresh now"/>
                <Button Grid.Column="2" Style="{StaticResource FlyoutGlyphButton}" Content="&#xE713;"
                        Command="{Binding OpenSettingsCommand}" ToolTip="Settings" Margin="4,0,0,0"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="560"
                          Visibility="{Binding HasConnectedProviders, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Providers}" ItemTemplate="{StaticResource ProviderCardTemplate}"/>
            </ScrollViewer>

            <!-- Empty state: shown instead of a column of "not connected" boxes. -->
            <StackPanel Grid.Row="1" Margin="20,26,20,22" HorizontalAlignment="Center"
                        Visibility="{Binding HasConnectedProviders, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="26"
                           HorizontalAlignment="Center" Opacity="0.55"
                           Foreground="{DynamicResource Brush.SecondaryText}"/>
                <TextBlock Text="No AI services connected" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,0"
                           HorizontalAlignment="Center" Foreground="{DynamicResource Brush.PrimaryText}"/>
                <TextBlock Text="Enable a service and sign in to its CLI. Connected services will appear here automatically."
                           FontSize="11.5" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,14" MaxWidth="280"
                           Foreground="{DynamicResource Brush.SecondaryText}"/>
                <Button Style="{StaticResource FlyoutPrimaryButton}" Content="Open Settings"
                        Command="{Binding OpenSettingsCommand}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
